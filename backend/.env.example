APP_NAME=Data-Berge OS
APP_ENV=local
CORS_ALLOW_ORIGINS=http://localhost:5173,http://localhost:3000
DB_PATH=../data/app.db
DATA_DIR=../data

# Optional. The deterministic analytics layer works without a model key.
# Provider default mode: use Agno's provider:model string and the provider's key.
AGNO_MODEL=openai:gpt-4.1-mini
OPENAI_API_KEY=

# Generic OpenAI-compatible endpoint mode.
# If AGNO_BASE_URL is set, the app uses AGNO_API_KEY + AGNO_BASE_URL instead of
# provider-specific defaults. This works for local/OpenAI-compatible servers.
AGNO_API_KEY=
AGNO_BASE_URL=

# Optional MLflow observability for profiling and LLM/agent chat runs.
MLFLOW_TRACKING_ENABLED=false
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=Data-Berge OS
MLFLOW_LOG_PROMPT_INSTANCES=false
MLFLOW_PROMPT_VERSION=query-analyst-v1
MLFLOW_QUERY_ANALYST_PROMPT_NAME=query-analyst-planner
MLFLOW_QUERY_ANALYST_PROMPT_VERSION=1
